{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@opensploit/core",
  "version": "0.1.0",
  "description": "Autonomous penetration testing plugin for OpenCode",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silicon-works/opensploit-plugin.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tui": {
      "import": "./src/tui.tsx",
      "config": {
        "enabled": true
      }
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "4.1.0",
    "zod": "4.1.8"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0",
    "@opentui/core": ">=0.1.97",
    "@opentui/solid": ">=0.1.97",
    "solid-js": ">=1.9.10"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.4.3",
    "@opentui/core": "0.1.97",
    "@opentui/solid": "0.1.97",
    "solid-js": "1.9.10",
    "@types/js-yaml": "4.0.9",
    "@types/bun": "latest",
    "effect": "4.0.0-beta.46",
    "typescript": "5.8.2"
  },
  "engines": {
    "opencode": ">=1.4.0"
  }
}
